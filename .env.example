# UI locale for setup scripts (zh-CN, en-US, or ja-JP). Leave empty to choose in the wizard.
VITOOM_LOCALE=

# Network region for setup scripts: cn (China mirrors) or intl. Leave empty to choose in the wizard.
VITOOM_REGION=
# Default admin password (admin@vitoom.ai). setup_vitoom.py generates a random 10-character value.
DEFAULT_ADMIN_PASSWORD=admin123456
# Backend image tag. Defaults to vitoom-backend:latest-${VITOOM_TARGET_ARCH} in docker-compose.yml.
# VITOOM_BACKEND_IMAGE=

# Optional Debian apt mirror for Docker builds.
# Example for China mainland:
# APT_MIRROR=https://mirrors.aliyun.com/debian
APT_MIRROR=

# Pandoc is installed from a local .deb prepared before docker build.
PANDOC_VERSION=3.6.4

# Optional pip mirror for Docker builds. Leave empty to use the default PyPI.
# Example for China mainland:
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=

# Target CPU architecture for Docker image builds (x86_64 or aarch64).
# Run `python scripts/setup_vitoom.py` before building images (mode: build).
VITOOM_TARGET_ARCH=

# Base URL for downloading prebuilt inference wheels via setup_vitoom.py (build mode).
# VITOOM_WHEEL_BASE_URL=http://192.168.31.17

# Host port exposed for browser/API access and used by the backend container.
VITOOM_SERVER_PORT=8888

# Backend public URL and inference containers → Backend HTTP URL.
# Use the Backend machine address, e.g. http://192.168.31.126:8888.
# Browser access and inference API calls both use this value.
VITOOM_BACKEND_URL=
VITOOM_WS_URL=

# Optional database URL. Leave empty for Docker and local defaults (/app/resources/data/vitoom.db in container).
# Do not use host paths like ./data/resources/... in Docker — that resolves to /app/data/... inside the container,
# outside the ./data/resources volume mount, and causes "unable to open database file".
# DATABASE_URL=

# Elasticsearch is bundled into the backend container for the built-in knowledge base.
ELASTICSEARCH_VERSION=8.15.5
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
KNOWLEDGE_BASE_ES_URL=http://127.0.0.1:9200
KNOWLEDGE_BASE_ES_USERNAME=

# Third-party Agent/API secrets. Keep these in the deployment .env, not in config files.
TAVILY_API_KEY=
KNOWLEDGE_BASE_ES_PASSWORD=
HR_BUSINESS_QUERY_ES_PASSWORD=

# Optional OpenClaw integration. Configure OpenClaw itself separately; Vitoom
# only needs to know how to reach the OpenClaw gateway.
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=

# Backend runtime settings.
LOG_LEVEL=INFO
VITOOM_SERVER_HOST=0.0.0.0
VITOOM_SERVER_DEBUG=false
VITOOM_SERVER_RELOAD=false

# Optional LiveTalking sidecar URL, for example http://192.168.31.17:8014.
VITOOM_SERVER_LIVETALKING_URL=

# ---------------------------------------------------------------------------
# Inference Docker release settings
# ---------------------------------------------------------------------------
# Inference services read VITOOM_BACKEND_URL / VITOOM_WS_URL above.

# Backend and inference both read this as inference.upload_auth_secret.
VITOOM_INFERENCE_UPLOAD_AUTH_SECRET=

# Inference service image tags (setup_vitoom.py overwrites by detected arch; see constants.py).
# VITOOM_VISUAL_IMAGE=tonera/vitoom-inference-visual:experimental-cu130-torch2.11-x86_64
# VITOOM_TEXT_IMAGE=tonera/vitoom-inference-text:experimental-cu130-torch2.11-x86_64
# VITOOM_AUDIO_IMAGE=tonera/vitoom-inference-audio:experimental-cu130-torch2.9.1-x86_64
# VITOOM_MINI_IMAGE=tonera/vitoom-inference-mini:experimental-cu130-torch2.11-x86_64
# VITOOM_DOWNLOAD_IMAGE=tonera/vitoom-inference-download:experimental-x86_64

# Host resource directories mounted into /app/resources/{models,weights,loras,outputs}.
# Defaults are project-root relative paths and work on Linux/macOS/Windows Docker Compose.
VITOOM_MODELS_HOST_DIR=./resources/models
VITOOM_WEIGHTS_HOST_DIR=./resources/weights
VITOOM_LORAS_HOST_DIR=./resources/loras
VITOOM_OUTPUTS_HOST_DIR=./resources/outputs

# Optional inference settings.
VITOOM_CIVITAI_TOKEN=
VITOOM_PIPELINE_CACHE_TTL_SECONDS=0
VITOOM_OVERWRITE_CONFIG=0

# Supervisor Agent (inference container; Backend proxies admin start/stop to these URLs).
# Per-service URLs for Backend admin proxy. Leave empty for services not deployed on this machine.
# Only set the URL(s) for inference profiles you run here, e.g. http://TEXT_HOST_IP:9002
# Agent auth reuses VITOOM_INFERENCE_UPLOAD_AUTH_SECRET; no separate supervisor token.
# Agent listen port inside each inference container.
VITOOM_SUPERVISOR_AGENT_PORT=9001
# Default host ports published by docker-compose.inference.release.yml:
#   visual=9001, text=9002, audio=9003, download=9004, mini=9005
VITOOM_VISUAL_SUPERVISOR_HOST_PORT=9001
VITOOM_TEXT_SUPERVISOR_HOST_PORT=9002
VITOOM_AUDIO_SUPERVISOR_HOST_PORT=9003
VITOOM_DOWNLOAD_SUPERVISOR_HOST_PORT=9004
VITOOM_MINI_SUPERVISOR_HOST_PORT=9005
VITOOM_VISUAL_SUPERVISOR_URL=
VITOOM_TEXT_SUPERVISOR_URL=
VITOOM_AUDIO_SUPERVISOR_URL=
VITOOM_DOWNLOAD_SUPERVISOR_URL=
VITOOM_MINI_SUPERVISOR_URL=
